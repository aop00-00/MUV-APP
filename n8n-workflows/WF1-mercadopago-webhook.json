    "IF: type == payment?":              { "main": [[{ "node": "🌐 Fetch Payment de MP",          "type": "main", "index": 0 }], [{ "node": "✅ OK (ignorar)", "type": "main", "index": 0 }]] },
    "🌐 Fetch Payment de MP":            { "main": [[{ "node": "IF: status == approved?",          "type": "main", "index": 0 }]] },
