    "🧾 Emitir CFDI / Factura":          { "main": [[{ "node": "💾 INSERT invoice en Supabase",    "type": "main", "index": 0 }]] },
    "💾 INSERT invoice en Supabase":     { "main": [[{ "node": "🪙 INSERT FitCoins (+1 por $10)",  "type": "main", "index": 0 }]] },
    "🪙 INSERT FitCoins (+1 por $10)":   { "main": [[{ "node": "📱 WhatsApp: Pago confirmado",     "type": "main", "index": 0 }]] },
