    {
      "parameters": {
        "url": "=https://api.fiscalprovider.mx/cfdi/emit",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerParameters": {
          "parameters": [{ "name": "Authorization", "value": "=Bearer {{ $env['TAX_PROVIDER_API_KEY'] }}" }]
        },
        "jsonParameters": true,
        "options": {},
        "bodyParametersJson": "={\n  \"reference_id\": \"{{ $('n12-tenant-update-order').item.json.id }}\",\n  \"customer_email\": \"{{ $('n12-tenant-update-order').item.json.user?.email }}\",\n  \"subtotal\": {{ $('n7-fetch-payment').item.json.transaction_amount / 1.16 }},\n  \"tax_amount\": {{ $('n7-fetch-payment').item.json.transaction_amount - ($('n7-fetch-payment').item.json.transaction_amount / 1.16) }},\n  \"total\": {{ $('n7-fetch-payment').item.json.transaction_amount }},\n  \"tax_region\": \"{{ $json.tax_region }}\",\n  \"rfc\": \"{{ $json.rfc }}\",\n  \"razon_social\": \"{{ $json.razon_social }}\",\n  \"description\": \"Servicios de fitness\",\n  \"issued_at\": \"{{ new Date().toISOString() }}\"\n}"
      },
      "id": "n15-emit-cfdi",
      "name": "Emit CFDI (PAC)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2660, 340]
    },
    {
      "parameters": {
        "operation": "create",
        "tableId": "invoices",
        "fieldsUi": {
          "fieldValues": [
            { "fieldId": "order_id",   "fieldValue": "={{ $('n12-tenant-update-order').item.json.id }}" },
            { "fieldId": "gym_id",     "fieldValue": "={{ $('n9-parse-ref').item.json.gymId }}" },
            { "fieldId": "user_id",    "fieldValue": "={{ $('n9-parse-ref').item.json.userId }}" },
            { "fieldId": "tax_region", "fieldValue": "MX" },
            { "fieldId": "status",     "fieldValue": "=={{ $json.success ? 'issued' : 'error' }}" },
            { "fieldId": "cfdi_uuid",  "fieldValue": "={{ $json.uuid || null }}" },
            { "fieldId": "pdf_url",    "fieldValue": "={{ $json.pdf_url || null }}" },
            { "fieldId": "xml_url",    "fieldValue": "={{ $json.xml_url || null }}" },
            { "fieldId": "subtotal",   "fieldValue": "={{ $('n7-fetch-payment').item.json.transaction_amount / 1.16 }}" },
            { "fieldId": "tax_amount", "fieldValue": "={{ $('n7-fetch-payment').item.json.transaction_amount * 0.16 / 1.16 }}" },
            { "fieldId": "total",      "fieldValue": "={{ $('n7-fetch-payment').item.json.transaction_amount }}" },
            { "fieldId": "issued_at",  "fieldValue": "={{ new Date().toISOString() }}" }
          ]
        }
      },
