            { "fieldId": "user_id",    "fieldValue": "={{ $('n9-parse-ref').item.json.userId }}" },
            { "fieldId": "amount",     "fieldValue": "={{ Math.floor($('n9-parse-ref').item.json.amount / 10) }}" },
            { "fieldId": "source",     "fieldValue": "purchase" },
            { "fieldId": "description","fieldValue": "=Compra +{{ Math.floor($('n9-parse-ref').item.json.amount / 10) }} FitCoins" }
          ]
        }
      },
      "id": "n17-award-fitcoins",
      "name": "Award FitCoins (+1 per $10)",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [2660, 580],
      "credentials": { "supabaseApi": { "id": "supabase-grind", "name": "Supabase Grind" } }
    },
    {
      "parameters": {
        "url": "=https://graph.facebook.com/v18.0/{{ $env['WHATSAPP_PHONE_ID'] }}/messages",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerParameters": {
          "parameters": [{ "name": "Authorization", "value": "=Bearer {{ $env['WHATSAPP_TOKEN'] }}" }]
        },
        "jsonParameters": true,
        "bodyParametersJson": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{ $('n13-get-gym-features').item.json.country_code || '52' }}{{ $('n12-tenant-update-order').item.json.user?.phone }}\",\n  \"type\": \"template\",\n  \"template\": {\n    \"name\": \"payment_confirmed\",\n    \"language\": { \"code\": \"es_MX\" },\n    \"components\": [{\n      \"type\": \"body\",\n      \"parameters\": [\n        { \"type\": \"text\", \"text\": \"{{ $('n12-tenant-update-order').item.json.user?.full_name?.split(' ')[0] || 'Socio' }}\" },\n        { \"type\": \"currency\", \"currency\": { \"fallback_value\": \"${{ $('n9-parse-ref').item.json.amount }} MXN\", \"code\": \"MXN\", \"amount_1000\": {{ $('n9-parse-ref').item.json.amount * 1000 }} } }\n      ]\n    }]\n  }\n}"
      },
      "id": "n18-whatsapp-notify",
      "name": "WhatsApp: Payment Confirmed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2880, 580]
    },
    {
