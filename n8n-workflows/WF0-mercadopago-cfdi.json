{
  "name": "Grind Project – MP Webhook + CFDI",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "mercado-pago",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "n1-webhook-trigger",
      "name": "Webhook: MP IPN",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [240, 300],
      "webhookId": "grind-mp-ipn"
    },
    {
      "parameters": {
        "jsCode": "// ── Verify Mercado Pago x-signature (HMAC-SHA256) ──────────────────────\n// See: https://www.mercadopago.com.mx/developers/es/docs/your-integrations/notifications/webhooks\n\nconst xSignature = $input.first().headers['x-signature'] || '';\nconst xRequestId = $input.first().headers['x-request-id'] || '';\nconst body = $input.first().body || {};\nconst secret = $env['MERCADO_PAGO_WEBHOOK_SECRET'];\n\nif (!secret) {\n  // Dev mode: skip verification\n  console.warn('[mp-webhook] No secret configured — skipping HMAC in dev');\n  return [{ json: { valid: true, body, xRequestId } }];\n}\n\nconst ts = (xSignature.match(/ts=(\\d+)/) || [])[1];\nconst v1 = (xSignature.match(/v1=([^,]+)/) || [])[1];\n\nif (!ts || !v1) {\n  return [{ json: { valid: false, reason: 'Missing ts or v1 in x-signature' } }];\n}\n\nconst dataId = body?.data?.id ?? '';\nconst manifest = `id:${dataId};request-id:${xRequestId};ts:${ts};`;\n\n// HMAC-SHA256 using Node.js crypto (available in n8n Function nodes)\nconst crypto = require('crypto');\nconst computed = crypto\n  .createHmac('sha256', secret)\n  .update(manifest)\n  .digest('base64');\n\nconst valid = computed === v1;\nreturn [{ json: { valid, body, xRequestId, manifest } }];"
      },
      "id": "n2-verify-hmac",
      "name": "Verify HMAC Signature",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [{ "value1": "={{ $json.valid }}", "value2": true }]
        }
      },
      "id": "n3-if-valid",
      "name": "IF: Signature Valid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [680, 300]
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "Unauthorized",
        "options": { "responseCode": 401 }
      },
      "id": "n4-reject",
      "name": "Respond 401",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [680, 500]
    },
    {
      "parameters": {
        "conditions": {
          "string": [{ "value1": "={{ $json.body.type }}", "value2": "payment" }]
        }
      },
      "id": "n5-if-payment",
      "name": "IF: type == payment?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [900, 300]
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "OK",
        "options": { "responseCode": 200 }
      },
      "id": "n6-ack-ok",
      "name": "Respond 200 OK (ignore)",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [900, 500]
    },
    {
      "parameters": {
        "url": "=https://api.mercadopago.com/v1/payments/{{ $json.body.data.id }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {},
        "headerParameters": {
          "parameters": [{
            "name": "Authorization",
            "value": "=Bearer {{ $env['MERCADO_PAGO_ACCESS_TOKEN_SAAS'] }}"
          }]
        }
      },
      "id": "n7-fetch-payment",
      "name": "Fetch MP Payment Details",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [{ "value1": "={{ $json.status }}", "value2": "approved" }]
        }
      },
      "id": "n8-if-approved",
      "name": "IF: status == approved?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "jsCode": "// Parse external_reference\n// Format: flow:{saas|tenant}:order:pending:user:{userId}[:gym:{gymId}]\nconst ref = $json.external_reference || '';\nconst paymentId = $json.id;\nconst amount = $json.transaction_amount;\n\nconst flowMatch = ref.match(/flow:(saas|tenant)/);\nconst userMatch = ref.match(/user:([^:]+)/);\nconst gymMatch  = ref.match(/gym:([^:]+)/);\n\nif (!flowMatch || !userMatch) {\n  throw new Error('Cannot parse external_reference: ' + ref);\n}\n\nreturn [{\n  json: {\n    flowType: flowMatch[1],\n    userId:   userMatch[1],\n    gymId:    gymMatch?.[1] || null,\n    paymentId: String(paymentId),\n    amount\n  }\n}];"
      },
      "id": "n9-parse-ref",
      "name": "Parse External Reference",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "rules": {
          "rules": [
            { "value": "saas", "outputKey": "saas", "output": 0 },
            { "value": "tenant", "outputKey": "tenant", "output": 1 }
          ]
        },
        "dataPropertyName": "flowType"
      },
      "id": "n10-switch-flow",
      "name": "Switch: SaaS vs Tenant",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 2,
      "position": [1780, 300]
    },
    {
      "parameters": {
        "operation": "update",
        "tableId": "gyms",
        "filters": {
          "conditions": [{ "keyName": "owner_id", "condition": "eq", "keyValue": "={{ $json.userId }}" }]
        },
        "fieldsUi": {
          "fieldValues": [
            { "fieldId": "plan_status", "fieldValue": "active" },
            { "fieldId": "saas_mp_payment_id", "fieldValue": "={{ $json.paymentId }}" },
            { "fieldId": "updated_at", "fieldValue": "={{ new Date().toISOString() }}" }
          ]
        }
      },
      "id": "n11-saas-update-gym",
      "name": "[SaaS] Activate Gym Plan",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [2000, 160],
      "credentials": { "supabaseApi": { "id": "supabase-grind", "name": "Supabase Grind" } }
    },
    {
      "parameters": {
        "operation": "update",
        "tableId": "orders",
        "filters": {
          "conditions": [
            { "keyName": "user_id", "condition": "eq", "keyValue": "={{ $json.userId }}" },
            { "keyName": "gym_id",  "condition": "eq", "keyValue": "={{ $json.gymId }}" },
            { "keyName": "status",  "condition": "eq", "keyValue": "pending" }
          ]
        },
        "fieldsUi": {
          "fieldValues": [
            { "fieldId": "status", "fieldValue": "paid" },
            { "fieldId": "mp_payment_id", "fieldValue": "={{ $json.paymentId }}" },
            { "fieldId": "updated_at", "fieldValue": "={{ new Date().toISOString() }}" }
          ]
        }
      },
      "id": "n12-tenant-update-order",
      "name": "[Tenant] Update Order → paid",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [2000, 440],
      "credentials": { "supabaseApi": { "id": "supabase-grind", "name": "Supabase Grind" } }
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "gyms",
        "filters": {
          "conditions": [{ "keyName": "id", "condition": "eq", "keyValue": "={{ $json.gymId }}" }]
        },
        "limit": 1
      },
      "id": "n13-get-gym-features",
      "name": "Get Gym Features & Config",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [2220, 440],
      "credentials": { "supabaseApi": { "id": "supabase-grind", "name": "Supabase Grind" } }
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [{ "value1": "={{ $json.features?.fiscal }}", "value2": true }]
        }
      },
      "id": "n14-if-fiscal",
      "name": "IF: fiscal feature enabled?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [2440, 440]
